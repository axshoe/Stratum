# ─────────────────────────────────────────────────────────────
# STRATUM — API KEYS
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your key.
# Only one key required — completely free.

# ── U.S. CENSUS BUREAU API KEY ────────────────────────────────
# Get yours at: https://api.census.gov/data/key_signup.html
# Free, instant approval, no credit card
# Provides: American Community Survey (ACS) 5-year estimates
#   - Income, education, housing, employment, broadband for every U.S. county
CENSUS_API_KEY=your_census_api_key_here

# ─────────────────────────────────────────────────────────────
# NO KEY REQUIRED (used automatically):
# • Opportunity Insights data  — pre-bundled CSV (Harvard)
# • BLS LAUS                   — public JSON API, no key needed
# • FCC broadband              — pre-bundled CSV
# ─────────────────────────────────────────────────────────────
